{
	"name": "@jackokerman/oxlint-config",
	"version": "1.9.0",
	"description": "Shared Oxlint config for Jack Okerman's JS and TS tools.",
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"jack-oxfmt-config": "./dist/oxfmt-config-cli.js",
		"slop-scan-check": "./dist/slop-scan-check-cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./oxfmt": {
			"types": "./dist/oxfmt-config.d.ts",
			"default": "./dist/oxfmt-config.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"check": "bun run check:public-content && bun run lint && bun run typecheck && bun run build",
		"check:public-content": "scripts/check-public-content.sh",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@jackokerman/comment-width-check": ">=1.1.0",
		"oxfmt": ">=0.56.0",
		"oxlint": ">=1.52.0"
	},
	"peerDependenciesMeta": {
		"@jackokerman/comment-width-check": {
			"optional": true
		},
		"oxfmt": {
			"optional": true
		}
	},
	"devDependencies": {
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.2",
		"@semantic-release/npm": "^13.1.2",
		"bun-types": "^1.3.13",
		"oxlint": "^1.52.0",
		"semantic-release": "^25.0.2",
		"typescript": "^5.7.0"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jackokerman/oxlint-config.git"
	},
	"license": "MIT",
	"dependencies": {
		"eslint-plugin-jsdoc": "61.4.0",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"slop-scan": "0.3.0"
	}
}
